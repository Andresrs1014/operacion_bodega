# ──────────────────────────────────────────────────────────────────────────────
# BRAKEPAK — Variables de entorno
# Copiar a .env y completar los valores reales
# ──────────────────────────────────────────────────────────────────────────────

# PostgreSQL
POSTGRES_DB=brakepak
POSTGRES_USER=brakepak
POSTGRES_PASSWORD=CAMBIAR_ESTA_CLAVE_SEGURA

# FastAPI
SECRET_KEY=CAMBIAR_POR_STRING_ALEATORIO_DE_64_CHARS
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_HOURS=8

# Gmail — usar App Password (NO la contraseña normal de Gmail)
# Activar en: myaccount.google.com > Seguridad > Contraseñas de aplicaciones
SMTP_USER=andres.desarrollo01@gmail.com
SMTP_PASSWORD=xxxx_xxxx_xxxx_xxxx

# Destinatarios de reportes (separados por coma, sin espacios)
REPORT_RECIPIENTS=coordinador.operaciones2@logimat.com.co,coordinador.operacionesb2@logimat.com.co
